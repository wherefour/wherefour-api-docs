{
  "summary": "Search for a location by name",
  "description": "Locates a location by name",
  "get": {
    "tags": [
      "Locations"
    ],
    "description": "Locates a location by name",
    "parameters": [
      {
        "in": "query",
        "name": "page",
        "description": "Results page to view",
        "schema": {
          "type": "integer"
        }
      },
      {
        "in": "query",
        "name": "name",
        "description": "Case-insensitive partial name search",
        "schema": {
          "type": "string"
        }
      },
      {
        "in": "query",
        "name": "locator_code",
        "description": "Case-insensitive partial locator code search",
        "schema": {
          "type": "string"
        }
      }
    ],
    "responses": {
      "200": {
        "description": "OK",
        "headers": {
          "Total": {
            "schema": {
              "type": "integer"
            },
            "description": "Total count of results"
          },
          "Per-Page": {
            "schema": {
              "type": "integer"
            },
            "description": "Number of results per page"
          },
          "Link": {
            "schema": {
              "type": "string"
            },
            "description": "URLs for the next or previous pages of the results"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../components/schemas/location.json"
            },
            "examples": {
              "Example": {
                "value": [
                  {
                    "id": 5,
                    "facility_id": 1,
                    "parent_location_id": null,
                    "name": "London Warehouse",
                    "locator_code": "LONW",
                    "global_identifier": "",
                    "locator_name_path": "Main Facility:London Warehouse",
                    "locator_code_path": "MAI:LONW",
                    "level_number": 1,
                    "level_name": "Zone",
                    "allowed_for_additives": true,
                    "allowed_for_pick_and_ship": true,
                    "allowed_for_returns": true,
                    "allowed_for_warehouse_receive": true,
                    "allowed_for_work_order_pulls": true,
                    "allowed_for_word_order_results": true,
                    "child_location_count": 0
                  },
                  {
                    "id": 6,
                    "facility_id": 1,
                    "parent_location_id": null,
                    "name": "Sydney Warehouse",
                    "locator_code": "SYDW",
                    "global_identifier": "",
                    "locator_name_path": "Main Facility:Sydney Warehouse",
                    "locator_code_path": "MAI:SYDW",
                    "level_number": 1,
                    "level_name": "Zone",
                    "allowed_for_additives": true,
                    "allowed_for_pick_and_ship": true,
                    "allowed_for_returns": true,
                    "allowed_for_warehouse_receive": true,
                    "allowed_for_work_order_pulls": true,
                    "allowed_for_word_order_results": true,
                    "child_location_count": 0
                  }
                ]
              }
            }
          }
        }
      }
    },
    "summary": "Search for locations",
    "operationId": "search_locations"
  },
  "parameters": [
    {
      "name": "name",
      "in": "query",
      "schema": {
        "type": "string",
        "minLength": 1
      },
      "required": false,
      "deprecated": false,
      "allowEmptyValue": false,
      "description": "Case-insensitive partial name search"
    }
  ]
}